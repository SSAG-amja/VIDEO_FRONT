# ==========================================
# 📱 핀름(Pinlm) 앱 환경 변수 템플릿
# ==========================================
# 사용 방법: 
# 1. 이 파일을 복사하여 프로젝트 최상단에 '.env' 파일을 만듭니다.
# 2. 아래의 더미 값들을 실제 본인의 로컬 IP 주소와 백엔드 포트로 변경하세요.
# ==========================================

# 백엔드 API 서버 기본 주소
# (현재 연결된 와이파이의 내부 IPv4 주소와 실제 백엔드가 실행 중인 포트를 입력하세요)
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:8000

# (선택) 추가적으로 사용할 환경 변수가 있다면 아래에 계속 추가하세요
# EXPO_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here